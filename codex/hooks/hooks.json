{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/static-dispatch.py\"",
            "statusMessage": "Checking git intent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/track-tokens.py\"",
            "statusMessage": "Tracking tokens"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${PLUGIN_ROOT}/scripts/statusline.py\"",
            "statusMessage": "Showing usage"
          }
        ]
      }
    ]
  }
}
