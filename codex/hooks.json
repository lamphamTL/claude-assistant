{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/git-intent.py",
            "statusMessage": "Checking git intent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/track-tokens.py",
            "statusMessage": "Tracking tokens"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/statusline.py",
            "statusMessage": "Showing usage"
          }
        ]
      }
    ]
  }
}
